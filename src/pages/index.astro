---
const name = "Amin Mezouer";
const subtitle = "Étudiant L3 Informatique";
const tags = ["Réseaux", "Cybersécurité", "Data / Data Science", "Python", "Linux"];

const about =
  "Étudiant en L3 Informatique (UVSQ / Université Paris-Saclay), je m’oriente vers les domaines réseaux, cybersécurité et data." +
  "Je construis des projets techniques en parallèle de mes cours : analyses réseau (Packet Tracer / Wireshark), " +
  "scripts et environnements Linux, ainsi que des exercices et mini-outils de cryptographie." +
  "J’aime comprendre la théorie pour mieux l’appliquer en pratique, et je documente mes projets et certifications sur GitHub et LinkedIn." +
  "" +
  "Objectif : intégrer un Master orienté réseaux/systèmes/cybersécurité et développer une expérience en alternance.";

const projects = [
  {
    title: "Projet Réseau",
    desc: "Études de topologies, configuration et diagnostic (TCP/IP, routage, VLAN). Utilisation de Packet Tracer et Wireshark pour analyser le trafic et comprendre les protocoles.",
    img: "images/project-network.png",
    url: "https://github.com/AmZzPYJS/Scan-port-localhost",
  },
  {
    title: "Projet Crypto",
    desc: "Implémentations et exercices autour des concepts de chiffrement, attaques simples, et outils de manipulation. Objectif : consolider les bases et développer une approche rigoureuse.",
    img: "images/project-crypto.png",
    url: "https://github.com/AmZzPYJS/chiffrement-2-cesar-crypto",
  },
  {
    title: "Projet Data",
    desc: "Nettoyage et exploration de données avec Pandas, analyses descriptives et visualisations. Objectif : produire des résultats clairs et reproductibles.",
    img: "images/project-data.png",
    url: "https://github.com/AmZzPYJS/InPoDa-Social-Data-Analysis",
  },
];

const certs = [
  {
    title: "Certification Pandas",
    org: "Manipulation de données tabulaires : sélection, filtrage, groupby, jointures, nettoyage.",
    img: "images/cert-pandas.png",
    url: "https://www.kaggle.com/learn/certification/amnmezouer/pandas",
  },
  {
    title: "Certification Linux",
    org: "Bases système : commandes, permissions, scripts Bash, environnement et pratiques.",
    img: "images/cert-linux.png",
    url: "https://www.credly.com/badges/2dde61b1-aa24-4698-9036-f0d9d3c0aeac/public_url",
  },
  {
    title: "Certification Python",
    org: "Base en Python : Dictionnaire, Liste, modularité, structure, fonction, importation",
    img: "images/cert-network.png",
    url: "https://www.hackerrank.com/certificates/f3bfd3182218",
  },
];
---
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title>{name} — Portfolio</title>
    <meta name="description" content="Portfolio projets, certifications et profil." />
    <style>
      :root{
        --bg:#0b1220; --card:#0f1a2e; --text:#e8eefc; --muted:#b6c2e2; --line:#1e2a44;
        --accent:#7aa2ff;
      }
      *{ box-sizing:border-box; }
      body{ margin:0; background:var(--bg); color:var(--text); }
      a{ color:var(--accent); text-decoration:none; }
      a:hover{ text-decoration:underline; }
      .container{ max-width: 980px; margin: 0 auto; padding: 56px 20px; }
      .center{ text-align:center; }
      .pillrow{ display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-top:18px; }
      .pill{ border:1px solid var(--line); color:var(--muted); padding:8px 12px; border-radius:999px; font-size:14px; }
      .hero h1{ font-size: 44px; margin: 0; letter-spacing: -0.02em; }
      .hero h2{ font-size: 18px; margin: 14px 0 0; color:var(--muted); font-weight:600; }
      .hero p{ margin: 18px auto 0; max-width: 720px; color:var(--muted); line-height: 1.6; }
      .actions{ margin-top: 22px; display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
      .btn{
        display:inline-block; padding:10px 14px; border-radius:12px;
        border:1px solid var(--line); background: transparent; color:var(--text);
      }
      .btn.primary{ background:var(--accent); border-color:transparent; color:#061024; font-weight:700; }
      .section{ margin-top: 60px; }
      .section h3{ margin:0 0 14px; font-size: 22px; }
      .grid{ display:grid; grid-template-columns: repeat(3, 1fr); gap:14px; }
      .card{
        border:1px solid var(--line); background:var(--card); border-radius:16px; overflow:hidden;
        transition: transform .15s ease, border-color .15s ease;
      }
      .card:hover{ transform: translateY(-2px); border-color:#2b3b60; }
.thumb{ width:100%; height:140px; object-fit:cover; display:block; background:#0a1426; }
      .cardbody{ padding:14px; }
      .cardtitle{ font-weight:800; margin:0; font-size:16px; }
      .carddesc{ margin:8px 0 0; color:var(--muted); line-height:1.5; font-size:14px; }
      .cardmeta{ margin-top:10px; color:var(--muted); font-size:13px; }
      footer{ margin-top: 70px; padding-top: 18px; border-top:1px solid var(--line); color:var(--muted); text-align:center; }
      @media (max-width: 900px){ .grid{ grid-template-columns: 1fr; } .hero h1{ font-size:36px; } }
</style>
  </head>

  <body>
    <main class="container">
      <!-- HERO -->
      <section class="hero center">
        <h1>{name}</h1>
        <h2>{subtitle}</h2>

        <div class="pillrow">
          {tags.map((t) => <span class="pill">{t}</span>)}
        </div>

        <p>{about}</p>

        <div class="actions">
          <a class="btn primary" href="#projects">Voir mes projets</a>
          <a class="btn" href="#certifications">Certifications</a>
          <a class="btn" href="https://github.com/AmZzPYJS" target="_blank" rel="noreferrer">GitHub</a>
          <a class="btn" href="https://www.linkedin.com/" target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </section>

      <!-- PROJECTS -->
      <section id="projects" class="section">
        <h3>Projets</h3>
        <div class="grid">
          {projects.map((p) => (
            <a class="card" href={p.url} target="_blank" rel="noreferrer" aria-label={p.title}>
              <img class="thumb" src={`${import.meta.env.BASE_URL}${p.img}`} alt={"Illustration " + p.title} />
              <div class="cardbody">
                <p class="cardtitle">{p.title}</p>
                <p class="carddesc">{p.desc}</p>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- CERTS -->
      <section id="certifications" class="section">
        <h3>Certifications</h3>
        <div class="grid">
          {certs.map((c) => (
            <a class="card" href={c.url} target="_blank" rel="noreferrer" aria-label={c.title}>
              <img class="thumb" src={`${import.meta.env.BASE_URL}${c.img}`} alt={"Certificat " + c.title} />
              <div class="cardbody">
                <p class="cardtitle">{c.title}</p>
                <p class="cardmeta">{c.org}</p>
              </div>
            </a>
          ))}
        </div>
      </section>

      <footer>
        © {new Date().getFullYear()} — {name}
      </footer>
    </main>
  </body>
</html>